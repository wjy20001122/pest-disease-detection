# FastAPI 应用配置
FASTAPI_APP_NAME=病虫害检测系统
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=9999
FASTAPI_REQUEST_TIMEOUT=60

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pdds
DB_USERNAME=pddsuser
DB_PASSWORD=your_password_here

# 阿里云 OSS 配置
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=pdds-files
OSS_DOMAIN=

# Socket.IO 配置
SOCKETIO_HEARTBEAT_INTERVAL=10

# FFmpeg 路径
FFMPEG_BINARY=ffmpeg

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_VIDEO_TASK_SOFT_TIME_LIMIT_SEC=1800
CELERY_VIDEO_TASK_HARD_TIME_LIMIT_SEC=2100
CELERY_VIDEO_TASK_MAX_RETRIES=2
CELERY_VIDEO_TASK_RETRY_BACKOFF_SEC=30

# JWT 密钥
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# DeepSeek API (可选)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ENABLE_CLOUD_ANALYSIS=true

# 和风天气API (可选)
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_BASE_URL=https://devapi.qweather.com

# 高德地图API (可选)
MAP_API_KEY=your-map-api-key
MAP_API_BASE_URL=https://restapi.amap.com

# 邮件验证码SMTP配置（用于注册验证/忘记密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM_EMAIL=your-email@example.com
SMTP_USE_SSL=true
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_COOLDOWN_SECONDS=60
